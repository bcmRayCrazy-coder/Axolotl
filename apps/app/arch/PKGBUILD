pkgname=axolotl-launcher
pkgver="${AXOLOTL_PKGVER:?AXOLOTL_PKGVER is required}"
pkgrel=1
pkgdesc='A cross-platform Minecraft launcher'
arch=('x86_64')
url='https://www.axlmc.org'
license=('GPL-3.0-only')
depends=(
	'libayatana-appindicator'
	'shared-mime-info'
	'webkit2gtk-4.1'
	'xdg-utils'
)
source=('axolotl-launcher.desktop' 'red.ghs.axolotl.xml')
sha256sums=('SKIP' 'SKIP')
options=('!strip')

package() {
	install -Dm755 "$AXOLOTL_BINARY" "$pkgdir/usr/bin/$pkgname"
	install -Dm644 "$srcdir/axolotl-launcher.desktop" \
		"$pkgdir/usr/share/applications/$pkgname.desktop"
	install -Dm644 "$srcdir/red.ghs.axolotl.xml" \
		"$pkgdir/usr/share/mime/packages/red.ghs.axolotl.xml"
	install -Dm644 "$AXOLOTL_ICON_DIR/32x32.png" \
		"$pkgdir/usr/share/icons/hicolor/32x32/apps/red.ghs.axolotl.png"
	install -Dm644 "$AXOLOTL_ICON_DIR/64x64.png" \
		"$pkgdir/usr/share/icons/hicolor/64x64/apps/red.ghs.axolotl.png"
	install -Dm644 "$AXOLOTL_ICON_DIR/128x128.png" \
		"$pkgdir/usr/share/icons/hicolor/128x128/apps/red.ghs.axolotl.png"
	install -Dm644 "$AXOLOTL_LICENSE" \
		"$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
